# Core credentials
NETWORK=mainnet
PARTY_ID=your_party_id_here
EMAIL=your_email_here
PASSWORD=your_password_here
PRIVATE_KEYS=your_loop_private_key_hex_here

# Pair and sizing
SYMBOL=Amulet/USDCx
TRADE_QTY=40
SELL_QTY=40
CC_RESERVE=10
BUY_CAP_CC=36
MIN_ORDER_QTY=35
TICK_SIZE=0.0001

# Strategy controls
# FORCE_SIDE: empty | buy | sell
FORCE_SIDE=
POLL_MS=500
REPLACE_COOLDOWN_MS=15000
REPLACE_IF_DRIFT_TICKS=1
MAX_ORDER_AGE_MS=180000
WAIT_APPEAR_MS=120000
WAIT_DISAPPEAR_MS=120000
MIN_CC_REMAIN=5
MIN_USDCX_REMAIN=1

# Cache TTLs (ms) — reduce API call frequency at 500ms polling
# Ticker re-fetched at most every 350ms (just under poll interval)
TICKER_CACHE_MS=350
# Active orders re-fetched at most every 2s
ACTIVE_ORDERS_CACHE_MS=2000
# Loop balances re-fetched at most every 15s
BALANCES_CACHE_MS=15000
# Loop session kept for 7 minutes before re-authenticating
LOOP_SESSION_TTL_MS=420000

# Auth failure cooldowns (ms) — prevents login hammering on bad credentials
# or temporary auth service degradation at 500ms poll rate
LOGIN_FAIL_COOLDOWN_MS=30000
LOOP_FAIL_COOLDOWN_MS=30000

# Safety
# Rate limit backoff reduced from 70s → 20s; fewer calls per second means
# we hit 429s less often so shorter recovery windows are fine.
RATE_LIMIT_BACKOFF_MS=20000
DRY_RUN=true
RUN_ONCE=false

# Optional overrides (usually not needed)
VALIDATOR_API_URL=https://api.templedigitalgroup.com
VALIDATOR_SCAN_API_URL=https://api.templedigitalgroup.com
VALIDATOR_USER_PARTY_ID=
